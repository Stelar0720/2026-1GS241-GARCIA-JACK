API_PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/?replicaSet=rs0&directConnection=true
MONGODB_DATABASE=urbansprout
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLERK_SECRET_KEY=
# Alternativa opcional para verificación JWT sin consulta remota:
CLERK_JWT_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
STOREFRONT_URL=http://localhost:3000

# MCP role keys (use long random values outside local development)
MCP_ADMIN_KEY=
MCP_SUPPORT_KEY=
MCP_CLIENT_KEY=
MCP_DEVELOPER_KEY=

# Free MongoDB JSON backups (stored in the protected backups collection)
BACKUP_DAILY_ENABLED=true
BACKUP_RETENTION=7
BACKUP_MAX_BYTES=12000000
# BACKUP_COLLECTIONS=products,inventory,orders,coupons,reviews,wishlist,admin_users,api_keys,processed_stripe_events,audit_logs,application_logs,tracked_errors
