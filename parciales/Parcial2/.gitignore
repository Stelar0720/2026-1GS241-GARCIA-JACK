# dependencies
/node_modules
/bun-api/node_modules/
/bun-api/package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# production
/dist
/build

# Sello de version: lo escribe el pipeline de CD antes de subir el codigo.
/bun-api/COMMIT

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!bun-api/.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo


#Ignore vscode AI rules
.github\instructions\codacy.instructions.md

