{
  "name": "@checkers/scripts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --filter=web dev",
    "dev:api": "bun run --filter=api dev",
    "dev:all": "bun run dev:api & bun run dev",
    "build": "bun run build",
    "build:api": "bun run --filter=api build",
    "build:web": "bun run --filter=web build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'No linter configured'",
    "docker:start": "docker compose -f docker/docker-compose.yml up --build -d",
    "docker:stop": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:migrate": "bun run --filter=api db:migrate",
    "db:studio": "bun run --filter=api db:studio",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "vitest": "^1.3.0"
  }
}
