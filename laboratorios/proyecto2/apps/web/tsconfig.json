{
  "name": "@checkers/web",
  "extends": "../../.base-tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    },
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": ["src/**/*", "*.tsx", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
